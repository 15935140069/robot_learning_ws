<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <!--
    Simple teaching parallel-jaw gripper.

    Coordinate convention inside this macro:
    - gripper_base_link +X: forward, away from tool0
    - finger opening/closing direction: +/-Y
    - +Z: up in the gripper local frame

    This is a learning model, not a vendor-specific gripper.
  -->
  <xacro:macro name="learning_parallel_gripper" params="
    parent
    tf_prefix:=''
    *origin
    ">

    <!-- Mounting body -->
    <link name="${tf_prefix}gripper_base_link">
      <visual>
        <origin xyz="0.045 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.09 0.08 0.05"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0.045 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.09 0.08 0.05"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0.045 0 0" rpy="0 0 0"/>
        <mass value="0.8"/>
        <inertia
          ixx="0.0010" ixy="0.0" ixz="0.0"
          iyy="0.0010" iyz="0.0"
          izz="0.0010"/>
      </inertial>
    </link>

    <joint name="${tf_prefix}tool0_to_gripper_base" type="fixed">
      <parent link="${parent}"/>
      <child link="${tf_prefix}gripper_base_link"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <!-- Left finger -->
    <link name="${tf_prefix}left_finger_link">
      <visual>
        <origin xyz="0.095 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.10 0.018 0.035"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0.095 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.10 0.018 0.035"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0.095 0 0" rpy="0 0 0"/>
        <mass value="0.12"/>
        <inertia
          ixx="0.00010" ixy="0.0" ixz="0.0"
          iyy="0.00010" iyz="0.0"
          izz="0.00010"/>
      </inertial>
    </link>

    <joint name="${tf_prefix}left_finger_joint" type="prismatic">
      <parent link="${tf_prefix}gripper_base_link"/>
      <child link="${tf_prefix}left_finger_link"/>
      <origin xyz="0.04 0.022 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="0.030" effort="40.0" velocity="0.08"/>
    </joint>

    <!-- Right finger -->
    <link name="${tf_prefix}right_finger_link">
      <visual>
        <origin xyz="0.095 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.10 0.018 0.035"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0.095 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.10 0.018 0.035"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0.095 0 0" rpy="0 0 0"/>
        <mass value="0.12"/>
        <inertia
          ixx="0.00010" ixy="0.0" ixz="0.0"
          iyy="0.00010" iyz="0.0"
          izz="0.00010"/>
      </inertial>
    </link>

    <joint name="${tf_prefix}right_finger_joint" type="prismatic">
      <parent link="${tf_prefix}gripper_base_link"/>
      <child link="${tf_prefix}right_finger_link"/>
      <origin xyz="0.04 -0.022 0" rpy="0 0 0"/>
      <axis xyz="0 -1 0"/>
      <limit lower="0.0" upper="0.030" effort="40.0" velocity="0.08"/>
    </joint>

  </xacro:macro>

</robot>
